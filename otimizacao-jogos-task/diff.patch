@@ -83,6 +106,7 @@ static void tl_closed(void *data,
 
     zwlr_foreign_toplevel_handle_v1_destroy(h);
     g_bar.dirty = true;
+    bar_update_render_suppressed();
     (void)data;
     LOG_INFO("taskbar: toplevel closed, remaining=%d", g_bar.toplevel_n);
 }
