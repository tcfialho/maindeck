#!/bin/sh

export XDG_CURRENT_DESKTOP=river
export XDG_SESSION_DESKTOP=river

# XKB keyboard layout: br primary, us secondary; Super+Space toggles between them
export XKB_DEFAULT_LAYOUT=br,us
export XKB_DEFAULT_VARIANT=,intl
export XKB_DEFAULT_OPTIONS=grp:win_space_toggle

mkdir -p "$HOME/.local/state/river"
exec >>"$HOME/.local/state/river/session.log" 2>&1

date
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP || true

/home/tcfialho/.local/bin/sunshine-session-start &

wlr-randr --output eDP-1 --mode 1920x1080@165.014999Hz || true

# maindeck-proxy disabled (we no longer have a proxy in this case)
# (
#     while true; do
#         maindeck-proxy 2>>"$HOME/.local/state/river/session.log"
#         echo "maindeck-proxy exited with status $?; restarting in 1s" \
#             >>"$HOME/.local/state/river/session.log"
#         sleep 1
#     done
# ) &

(
    while true; do
        env XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" \
            GDK_BACKEND=wayland \
            WAYLAND_DISPLAY="wayland-1" \
            /home/tcfialho/.local/bin/maindeck-bar

        status=$?
        echo "maindeck-bar exited with status ${status}; restarting in 1s"
        sleep 1
    done
) &

while true; do
    /home/tcfialho/.local/bin/maindeck-wm
    status=$?
    echo "maindeck-wm exited with status ${status}; restarting in 1s"
    sleep 1
done
